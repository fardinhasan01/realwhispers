# Cloudinary (server only — never expose API secret in frontend)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Upload server
UPLOAD_PORT=3001
CORS_ORIGIN=*

# Firebase Admin (required for secure upload auth + room membership check)
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_DATABASE_URL=https://whispers-2c228-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=whispers-2c228
# Paste entire service account JSON as a single line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Frontend (Vite — only public values)
# Web dev uses Vite proxy (/api). Android/production needs full URL:
# VITE_UPLOAD_API_URL=https://your-upload-server.com/api
